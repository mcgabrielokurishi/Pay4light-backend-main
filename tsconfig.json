{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "lib": ["ES2021"],

    "declaration": false,
    "sourceMap": true,

    "rootDir": ".",
    "outDir": "./dist",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "baseUrl": ".",

    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "src/**/*",
    "prisma/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts"
  ]
}