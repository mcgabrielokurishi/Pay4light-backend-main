generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum TransactionType {
ELECTRICITY_PURCHASE
  WALLET_CREDIT
  WALLET_DEBIT
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum MeterType {
  PREPAID
  POSTPAID
}

enum VendorStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum UtilityStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Role {
  USER
  ADMIN
}

enum OtpPurpose {
  REGISTER
  LOGIN
  PASSWORD_RESET
  FUND_WALLET
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  name        String?
  ipAddress   String?
  userAgent   String?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

model VendorTransaction {
  id              String       @id @default(uuid())
  userId          String
  reference       String       @unique
  provider        String
  serviceType     String
  token           String?
  meterID         String?
  units           String?
  amount          Decimal      @default(0)
  status          VendorStatus
  requestPayload  Json
  responsePayload Json?
  externalRef     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model OTP {
  id        String     @id @default(uuid())
  userId    String?
  phone     String?
  email     String?
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  phone    String? @unique
  password String
  role     Role    @default(USER)

  firstName      String?
  lastName       String?
  fullName       String?
  failedAttempts Int       @default(0)
  lockedUntill   DateTime?
  discoId      String? 
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  wallet               Wallet?
  transactions         Transaction[]
  electricityPurchases ElectricityPurchase[]
  conversations        AIConversation[]
  otps                 OTP[]
  devices              Device[]
  Meter                Meter[]
  disco Disco? @relation(fields: [discoId], references: [id])
}

model LedgerEntry {
  id            String            @id @default(uuid())
  walletId      String
  accountId     String
  transactionId String
  type          String
  amount        Decimal           @default(0)
  balanceBefore Decimal           @default(0)
  balanceAfter  Decimal           @default(0)
  description   String?
  metadata      Json?
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  account       LedgerAccount     @relation(fields: [accountId], references: [id])
  wallet        Wallet            @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LedgerAccount {
  id        String  @id @default(uuid())
  name      String
  accountId String
  type      String // USER, SYSTEM, VENDOR
  userId    String? // if user wallet
  balance   Decimal @default(0)

  createdAt DateTime      @default(now())
  entries   LedgerEntry[]
}

model LedgerTransaction {
  id            String  @id @default(uuid())
  reference     String  @unique
  description   String?
  walletId      String
  transactionId Json
  status        String // PENDING, SUCCESS, FAILED

  entries   LedgerEntry[]
  createdAt DateTime      @default(now())
}

model Wallet {
  id       String  @id @default(uuid())
  userId   String  @unique
  amount   Decimal @default(0)
  balance  Decimal @default(0)
  currency String  @default("NGN")
  locked   Boolean @default(false)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  entries   LedgerEntry[]

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  walletId    String
  meterId     String
  metadata    Json
  type        TransactionType
  token       String?
  amount      Decimal
  kwh         Float?
  reference   String            @unique
  status      TransactionStatus @default(PENDING)
  description String?

  createdAt DateTime @default(now())

  meter Meter @relation(fields: [meterId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  electricityPurchase ElectricityPurchase?
}

model ElectricityPurchase {
  id            String @id @default(uuid())
  userId        String
  transactionId String @unique

  disco       String
  meterNumber String
  meterType   MeterType

  units  Decimal?
  token  String?
  status UtilityStatus @default(PENDING)

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  role      String // "user" | "assistant"
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Meter {
 id          String   @id @default(cuid())
  userId      String
  meterNumber String   @unique
  meterType   MeterType
  discoId     String
  address     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  

  user User @relation(fields: [userId], references: [id])
  disco        Disco         @relation(fields: [discoId], references: [id])
  transactions Transaction[]
}


model Disco {
  id           String  @id @default(cuid())
  name         String  // e.g "Ikeja Electric"
  code         String  @unique // e.g "IKEDC"
  tariffRate   Float   // naira per kWh
  supportPhone String?
  states       String
  supportEmail String?
  website      String?
  isActive     Boolean @default(true)
  
  
  meters Meter[]
  users  User[]
}