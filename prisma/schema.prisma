generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  name        String?
  ipAddress   String?
  userAgent   String?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

model VendorTransaction {
  id              String   @id @default(uuid())
  userId          String
  reference       String   @unique
  provider        String
  serviceType     String
  token           String?
  meterID         String?
  units           String?
  amount          Float    @default(0)
  status          String
  requestPayload  String
  responsePayload String?
  externalRef     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OTP {
  id        String   @id @default(uuid())
  userId    String?
  phone     String?
  email     String?
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  phone    String? @unique
  password String
  role     String  @default("USER")

  firstName      String?
  lastName       String?
  fullName       String?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  discoId        String?
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  wallet               Wallet?
  transactions         Transaction[]
  electricityPurchases ElectricityPurchase[]
  conversations        AIConversation[]
  otps                 OTP[]
  devices              Device[]
  meters               Meter[]

  disco Disco? @relation(fields: [discoId], references: [id])
}

model LedgerEntry {
  id            String   @id @default(uuid())
  walletId      String
  accountId     String
  transactionId String
  type          String
  amount        Float    @default(0)
  balanceBefore Float    @default(0)
  balanceAfter  Float    @default(0)
  description   String?
  metadata      String?

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id])
  account     LedgerAccount     @relation(fields: [accountId], references: [id])
  wallet      Wallet            @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LedgerAccount {
  id        String  @id @default(uuid())
  name      String
  accountId String
  type      String
  userId    String?
  balance   Float   @default(0)

  createdAt DateTime @default(now())
  entries   LedgerEntry[]
}

model LedgerTransaction {
  id            String  @id @default(uuid())
  reference     String  @unique
  description   String?
  walletId      String
  transactionId String
  status        String

  entries   LedgerEntry[]
  createdAt DateTime @default(now())
}

model Wallet {
  id       String  @id @default(uuid())
  userId   String  @unique
  amount   Float   @default(0)
  balance  Float   @default(0)
  currency String  @default("NGN")
  locked   Boolean @default(false)

  virtualAccountNuban String?
  virtual_account_bank String?
  virtual_account_ref  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries      LedgerEntry[]
  transactions Transaction[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String  @id @default(uuid())
  userId      String
  walletId    String
  meterId     String?
  metadata    String
  type        String
  token       String?
  amount      Float
  kwh         Float?
  reference   String  @unique
  status      String  @default("PENDING")
  description String?

  createdAt DateTime @default(now())

  meter Meter? @relation(fields: [meterId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  electricityPurchase ElectricityPurchase?
}

model ElectricityPurchase {
  id            String @id @default(uuid())
  userId        String
  transactionId String @unique

  disco       String
  meterNumber String
  meterType   String

  units  Float?
  token  String?
  status String @default("PENDING")

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  role      String
  message   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Meter {
  id          String   @id @default(cuid())
  userId      String
  meterNumber String   @unique
  meterType   String
  discoId     String
  address     String?
  meterName   String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  disco Disco @relation(fields: [discoId], references: [id])

  transactions Transaction[]
}

model Disco {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique
  tariffRate   Float
  supportPhone String?
  states       String
  supportEmail String?
  website      String?
  isActive     Boolean @default(true)

  meters Meter[]
  users  User[]
}