generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  deviceId    String
  name        String?
  ipAddress   String?
  userAgent   String?
  lastLoginAt DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  pushEnabled       Boolean  @default(true)
  pushTransactions  Boolean  @default(true)
  pushElectricity   Boolean  @default(true)
  pushSecurity      Boolean  @default(true)
  pushPromotions    Boolean  @default(true)
  pushLowBalance    Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  emailTransactions Boolean  @default(true)
  emailElectricity  Boolean  @default(true)
  emailSecurity     Boolean  @default(true)
  emailPromotions   Boolean  @default(false)
  emailLowBalance   Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  inAppTransactions Boolean  @default(true)
  inAppElectricity  Boolean  @default(true)
  inAppSecurity     Boolean  @default(true)
  inAppPromotions   Boolean  @default(true)
  inAppLowBalance   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Information {
  id          String       @id @default(cuid())
  title       String
  content     String
  category    InfoCategory @default(GENERAL)
  isPublished Boolean      @default(true)
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model MeterUsageStats {
  id                 String    @id @default(cuid())
  userId             String
  meterId            String
  avgDailyUsage      Float
  avgDaysBetweenBuys Float
  lastPurchaseDate   DateTime?
  lastPurchaseUnits  Float?
  forecastedRunOutAt DateTime?
  daysRemaining      Int?
  lastCalculatedAt   DateTime  @default(now())
  meter              Meter     @relation(fields: [meterId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, meterId])
}

model VendorTransaction {
  id              String   @id @default(uuid())
  userId          String
  reference       String   @unique
  provider        String
  serviceType     String
  token           String?
  meterID         String?
  units           String?
  amount          Float    @default(0)
  status          String
  externalRef     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  requestPayload  Json?
  responsePayload Json?
  user            User     @relation(fields: [userId], references: [id])
}

model SavedCard {
  id                String   @id @default(cuid())
  userId            String
  authorizationCode String
  cardType          String?
  last4             String
  expMonth          String?
  expYear           String?
  bank              String?
  brand             String?
  email             String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTP {
  id        String   @id @default(uuid())
  userId    String?
  phone     String?
  email     String?
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String                @id @default(uuid())
  email                String?               @unique
  phone                String?               @unique
  password             String
  firstName            String?
  lastName             String?
  fullName             String?
  failedAttempts       Int                   @default(0)
  lockedUntil          DateTime?
  discoId              String?
  isVerified           Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  isActive             Boolean               @default(true)
  bvn                  String?
  nin                  String?
  role                 Role                  @default(USER)
  conversations        AIConversation[]
  bankAccounts         BankAccount[]
  cards                Card[]
  devices              Device[]
  deviceToken          DeviceToken[]
  electricityPurchases ElectricityPurchase[]
  meters               Meter[]
  meterUsageStats      MeterUsageStats[]
  notifications        Notification[]
  notificationSettings NotificationSettings?
  otps                 OTP[]
  pushNotification     PushNotification[]
  refreshTokens        RefreshToken[]
  savedCards           SavedCard[]
  transactions         Transaction[]
  disco                Disco?                @relation(fields: [discoId], references: [id])
  vendorTransactions   VendorTransaction[]
  wallet               Wallet?
  meterApplications    MeterApplication[]
  documents            Document[]
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountNumber])
}

model Card {
  id             String   @id @default(uuid())
  userId         String
  cardToken      String
  last4          String
  brand          String
  expMonth       String
  expYear        String
  cardHolderName String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardToken])
}

model LedgerEntry {
  id            String            @id @default(uuid())
  walletId      String
  accountId     String
  transactionId String
  type          String
  amount        Float             @default(0)
  balanceBefore Float             @default(0)
  balanceAfter  Float             @default(0)
  description   String?
  metadata      String?
  createdAt     DateTime          @default(now())
  account       LedgerAccount     @relation(fields: [accountId], references: [id])
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  wallet        Wallet            @relation(fields: [walletId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LedgerAccount {
  id        String        @id @default(uuid())
  name      String
  accountId String
  type      String
  userId    String?
  balance   Float         @default(0)
  createdAt DateTime      @default(now())
  entries   LedgerEntry[]
}

model LedgerTransaction {
  id            String        @id @default(uuid())
  reference     String        @unique
  description   String?
  walletId      String
  transactionId String
  status        String
  createdAt     DateTime      @default(now())
  entries       LedgerEntry[]
}

model Wallet {
  id                   String        @id @default(uuid())
  userId               String        @unique
  amount               Float         @default(0)
  balance              Float         @default(0)
  currency             String        @default("NGN")
  locked               Boolean       @default(false)
  virtualAccountNuban  String?
  virtual_account_bank String?
  virtual_account_ref  String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  entries              LedgerEntry[]
  transactions         Transaction[]
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                  String               @id @default(uuid())
  userId              String
  walletId            String
  meterId             String?
  metadata            String
  type                String
  token               String?
  amount              Float
  kwh                 Float?
  reference           String               @unique
  status              String               @default("PENDING")
  description         String?
  createdAt           DateTime             @default(now())
  electricityPurchase ElectricityPurchase?
  meter               Meter?               @relation(fields: [meterId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet              Wallet               @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model ElectricityPurchase {
  id            String      @id @default(uuid())
  userId        String
  transactionId String      @unique
  disco         String
  meterNumber   String
  meterType     String
  units         Float?
  token         String?
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meter {
  id              String            @id @default(cuid())
  userId          String
  meterNumber     String            @unique
  meterType       String
  discoId         String
  address         String?
  meterName       String?
  isDefault       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  disco           Disco             @relation(fields: [discoId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  meterUsageStats MeterUsageStats[]
  transactions    Transaction[]
}
model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json     // stores full conversation history
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Disco {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique
  tariffRate   Float
  supportPhone String?
  states       String
  supportEmail String?
  website      String?
  isActive     Boolean @default(true)
  meters          Meter[]
  users           User[]
  meterApplications MeterApplication[]
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  Platform @default(ANDROID)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushNotification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  body      String
  data      Json?
  type      NotificationType @default(INFO)
  status    PushStatus       @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeterApplication {
  id              String          @id @default(uuid())
  reference       String          @unique @db.VarChar(20)

  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  discoId         String
  disco           Disco           @relation(fields: [discoId], references: [id])

  address         String
  state           String          @db.VarChar(60)
  lga             String          @db.VarChar(80)

  propertyType    PropertyType
  occupancy       Occupancy
  supplyPhase     SupplyPhase

  loadEstimateKva Decimal         @db.Decimal(6, 2)

  intendedUse     IntendedUse
  appliancesNotes String?

  status          ApplicationStatus @default(DRAFT)

  feePaid         Boolean         @default(false)
  feeAmount       Decimal         @db.Decimal(10, 2)

  submittedAt     DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  documents       Document[]

  @@index([status])
}

model Document {
  id             String            @id @default(uuid())

  applicationId  String
  application    MeterApplication  @relation(fields: [applicationId], references: [id])

  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  docType        DocumentType

  fileUrl        String
  fileSizeKb     Int
  mimeType       String            @db.VarChar(60)

  verified       Boolean           @default(false)

  uploadedAt     DateTime          @default(now())

  @@index([applicationId])
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  DRIVERS_LICENSE
  UTILITY_BILL
  TENANCY_AGREEMENT
  CAC_CERTIFICATE
  PROPERTY_DOCUMENT
  PASSPORT_PHOTOGRAPH
  OTHER
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  MIXED_USE
}

enum Occupancy {
  OWNER_OCCUPIED
  TENANT
}

enum SupplyPhase {
  SINGLE_PHASE
  THREE_PHASE
}

enum IntendedUse {
  HOME
  BUSINESS
  INDUSTRIAL
}

enum ApplicationStatus {
  DRAFT
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}
enum Role {
  USER
  ADMIN
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  TRANSACTION
  ELECTRICITY
  SYSTEM
}

enum Platform {
  ANDROID
  IOS
  WEB
}

enum PushStatus {
  PENDING
  SENT
  FAILED
}

enum InfoCategory {
  GENERAL
  ELECTRICITY
  BILLING
  SAFETY
  FAQ
  TIP
}
